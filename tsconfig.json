{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "nodenext",
    "types": ["node", "@playwright/test"],
    "strict": true,
    "esModuleInterop": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "include": ["tests/**/*.ts", "playwright.config.ts", "auth/auth.setup.ts"],
  "exclude": ["node_modules"]
}
